    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20250410.0",
    "@playwright/test": "^1.52.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "wrangler": "^4.12.0"
  }
}
